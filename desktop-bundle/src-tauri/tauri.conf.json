{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "moonshot",
  "version": "0.1.0",
  "identifier": "io.github.joeyparrish.moonshot",
  "build": {
    "frontendDist": "../../MoonShot.materials/Release/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MoonShot",
        "minWidth": 640,
        "minHeight": 480,
        "width": 1280,
        "height": 720,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
